// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String? // Optional for OTP-only users
  googleId          String?   @unique
  picture           String? // Profile image: URL (Google) or base64 data URL (uploaded)
  emailVerified     Boolean   @default(false)
  profilePublic     Boolean   @default(true) @map("profile_public") // public profile visibility
  lastGridExtractAt DateTime? @map("last_grid_extract_at")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  otpVerifications       OTPVerification[]
  sessions               Session[]
  vehicles               Vehicle[]
  locations              Location[]
  routes                 Route[]
  places                 Place[]
  placeReviews           PlaceReview[]
  placePhotos            PlacePhoto[]
  favorites              Favorite[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  businessClaims         BusinessClaim[]
  placeLabels            PlaceLabel[]

  ownedItineraries     Itinerary[]        @relation("ItineraryOwner")
  itineraryMemberships ItineraryMember[]
  itineraryComments    ItineraryComment[]
  itineraryVotes       ItineraryVote[]

  @@index([email])
  @@index([googleId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String // place_submitted | place_added | place_approved
  title     String
  body      String   @db.Text
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// Per-user notification category preferences. A missing row means "all on"
// (the defaults below). pushEnabled is the master switch for web-push delivery;
// the per-category flags gate whether a notification of that kind is created at
// all (used to convert former broadcast-to-all sends into opt-in targeted ones).
model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  pushEnabled   Boolean  @default(true) @map("push_enabled")
  placeApproved Boolean  @default(true) @map("place_approved")
  placeAdded    Boolean  @default(true) @map("place_added")
  festival      Boolean  @default(true)
  businessClaim Boolean  @default(true) @map("business_claim")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OTPVerification {
  id        String   @id @default(uuid())
  email     String
  otp       String
  type      String // 'register' or 'login'
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  @@index([email, otp])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Vehicle {
  id           String   @id @default(uuid())
  name         String
  licensePlate String?  @unique
  type         String // 'car', 'truck', 'bike', etc.
  status       String   @default("idle") // 'idle', 'active', 'maintenance'
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations Location[]
  routes    Route[]

  @@index([userId])
  @@index([status])
}

model Location {
  id        String   @id @default(uuid())
  vehicleId String?
  userId    String?
  latitude  Float
  longitude Float
  accuracy  Float? // GPS accuracy in meters
  speed     Float? // Speed in km/h
  heading   Float? // Direction in degrees (0-360)
  timestamp DateTime @default(now())

  // PostGIS geometry column
  point Unsupported("geometry(Point,4326)")?

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([userId])
  @@index([timestamp])
  @@index([latitude, longitude])
}

model Route {
  id          String    @id @default(uuid())
  vehicleId   String?
  userId      String
  name        String?
  startLat    Float
  startLng    Float
  endLat      Float
  endLng      Float
  waypoints   Json? // Array of {lat, lng} waypoints
  distance    Float? // Distance in meters
  duration    Int? // Duration in seconds
  polyline    String? // Encoded polyline
  status      String    @default("planned") // 'planned', 'active', 'completed', 'cancelled'
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Place {
  id                 String                               @id @default(uuid())
  name               String // Legacy: kept for backward compat; equals place_name_en for new places
  placeNameEn        String?                              @map("place_name_en") // English name (preferred)
  placeNameLocal     String?                              @map("place_name_local") // Local language name (Kannada, Tamil, etc.)
  category           String // Restaurant, Hospital, Hotel, Parking, Shop, Tourist Place, etc.
  latitude           Float
  longitude          Float
  zoomLevel          Float                                @default(15)
  userId             String
  userName           String?                              @map("user_name") // User name when place was added
  userEmail          String?                              @map("user_email") // User email when place was added
  source             String                               @default("contribution") // 'contribution' = Add Place, 'saved' = save from search
  approvalStatus     String                               @default("pending") @map("approval_status") // pending | approved | rejected
  approvedAt         DateTime?                            @map("approved_at")
  autoApproveAt      DateTime?                            @map("auto_approve_at")
  googlePlaceId      String?                              @map("google_place_id")
  googleType         String?                              @map("google_type")
  googleTypes        Json?                                @map("google_types")
  googleMapsUrl      String?                              @map("google_maps_url")
  vicinity           String?
  fullAddress        String?                              @map("full_address")
  village            String?
  taluk              String?
  district           String?
  state              String?
  country            String?
  pincode            String?
  phone              String?
  website            String?
  rating             Float?
  reviewCount        Int?                                 @map("review_count")
  openingHours       Json?                                @map("opening_hours")
  businessStatus     String?                              @map("business_status")
  description        String?                              @db.Text
  googleReviews      Json?                                @map("google_reviews")
  nearbyPlaces       Json?                                @map("nearby_places")
  googlePhotos       Json?                                @map("google_photos")
  mapRenderingConfig Json?                                @map("map_rendering_config")
  extractedAt        DateTime?                            @map("extracted_at")
  // Festival / jatre overlay: time-bound markers shown only during their window.
  festivalStartDate  DateTime?                            @map("festival_start_date")
  festivalEndDate    DateTime?                            @map("festival_end_date")
  festivalRecurrence String?                              @map("festival_recurrence") // 'yearly' | 'none'
  festivalNotifiedAt DateTime?                            @map("festival_notified_at") // last occurrence start we broadcast to all users
  // Business ownership: set when an admin approves a BusinessClaim for this place.
  claimedById        String?                              @map("claimed_by_id")
  claimVerifiedAt    DateTime?                            @map("claim_verified_at")
  // PostGIS geometry, kept in sync with latitude/longitude by a DB trigger.
  // Enables GiST-indexed ST_DWithin / ST_Contains spatial queries.
  geom               Unsupported("geometry(Point,4326)")?
  createdAt          DateTime                             @default(now())
  updatedAt          DateTime                             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  reviews   PlaceReview[]
  photos    PlacePhoto[]
  favorites Favorite[]
  claims    BusinessClaim[]
  labels    PlaceLabel[]

  @@unique([userId, googlePlaceId])
  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@index([source])
  @@index([approvalStatus])
  @@index([autoApproveAt])
  @@index([latitude, longitude])
  @@index([googlePlaceId])
  @@index([extractedAt])
  @@index([festivalStartDate])
  // Composite indexes for the common list / search access patterns.
  @@index([approvalStatus, category])
  @@index([approvalStatus, createdAt])
}

// User-specific personal bookmark / favorite of a location.
// Unlike Place (which represents a place on the public map), Favorite
// is a lightweight bookmark relation between a user and either an
// existing Place (placeId set) or an arbitrary lat/lng (e.g. external
// search result). Saving never creates a Place row, and unsaving only
// removes the Favorite — the underlying Place is preserved.
model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  placeId   String?  @map("place_id")
  name      String
  latitude  Float
  longitude Float
  category  String?
  address   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([placeId])
  @@index([userId, latitude, longitude])
}

model PlaceReview {
  id        String   @id @default(uuid())
  placeId   String
  userId    String
  userName  String?  @map("user_name")
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([userId])
}

model PlacePhoto {
  id        String   @id @default(uuid())
  placeId   String
  userId    String
  userName  String?  @map("user_name")
  dataUrl   String // base64 data URL (jpeg, compressed)
  caption   String?
  createdAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@index([userId])
}

// Business ownership claim. A user requests to be recognized as the owner /
// manager of a place; an admin reviews and approves or rejects it. On approval
// the Place is stamped with claimedById + claimVerifiedAt (the "verified" badge).
model BusinessClaim {
  id           String    @id @default(uuid())
  placeId      String    @map("place_id")
  userId       String    @map("user_id")
  userName     String?   @map("user_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  role         String    @default("owner") // owner | manager | employee | other
  message      String?   @db.Text
  status       String    @default("pending") // pending | approved | rejected
  reviewNote   String?   @map("review_note") @db.Text
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([userId])
  @@index([status])
}

// Personal, per-user label for a place (Google Maps "Add a label" — e.g. Home,
// Work, Favourite). Private to the user; does not affect the public place.
model PlaceLabel {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  placeId   String?  @map("place_id")
  label     String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([userId])
  @@index([placeId])
}

// Public provenance / audit trail for every place lifecycle event.
// Intentionally NOT linked to Place via a foreign key: when a Place row is
// hard-deleted we still want to preserve its full history (Wikipedia-style
// transparency), so audit rows survive deletion. `actorId` is likewise a loose
// reference (no FK) so the trail outlives user deletions.
model PlaceAudit {
  id        String   @id @default(uuid())
  placeId   String   @map("place_id")
  action    String // created | updated | approved | rejected | deleted | restored
  actorType String   @default("user") @map("actor_type") // user | admin | system
  actorId   String?  @map("actor_id")
  actorName String?  @map("actor_name")
  changes   Json? // { field: { old, new } } diff for this event
  snapshot  Json? // full place snapshot at this version (used for restore)
  note      String?  @db.Text // optional human note (e.g. "auto-approved")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([placeId, createdAt])
  @@index([action])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Co-Edited Group Itineraries — collaborative trip planning.
// An Itinerary is a shared trip owned by one user and co-edited by members.
// Stops are ordered places; members vote (like/dislike) and comment on each
// stop, and the stop order can be auto-sorted by net votes. A share token lets
// anyone with the link join as an editor.
// ---------------------------------------------------------------------------
model Itinerary {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  ownerId     String    @map("owner_id")
  shareToken  String    @unique @map("share_token")
  coverEmoji  String?   @map("cover_emoji")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  autoSort    Boolean   @default(false) @map("auto_sort") // reorder stops by net votes
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner   User              @relation("ItineraryOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members ItineraryMember[]
  stops   ItineraryStop[]

  @@index([ownerId])
  @@index([shareToken])
  @@index([updatedAt])
}

model ItineraryMember {
  id          String   @id @default(uuid())
  itineraryId String   @map("itinerary_id")
  userId      String   @map("user_id")
  role        String   @default("editor") // owner | editor | viewer
  createdAt   DateTime @default(now()) @map("created_at")

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, userId])
  @@index([userId])
  @@index([itineraryId])
}

model ItineraryStop {
  id          String   @id @default(uuid())
  itineraryId String   @map("itinerary_id")
  placeId     String?  @map("place_id") // optional link to an existing Place
  name        String
  category    String?
  latitude    Float
  longitude   Float
  address     String?
  notes       String?  @db.Text
  position    Int      @default(0) // manual order index within the trip
  dayIndex    Int?     @map("day_index")
  addedById   String?  @map("added_by_id")
  addedByName String?  @map("added_by_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  itinerary Itinerary          @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  comments  ItineraryComment[]
  votes     ItineraryVote[]

  @@index([itineraryId, position])
}

model ItineraryComment {
  id        String   @id @default(uuid())
  stopId    String   @map("stop_id")
  userId    String   @map("user_id")
  userName  String?  @map("user_name")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  stop ItineraryStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stopId, createdAt])
}

model ItineraryVote {
  id        String   @id @default(uuid())
  stopId    String   @map("stop_id")
  userId    String   @map("user_id")
  value     Int // 1 = like, -1 = dislike
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stop ItineraryStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stopId, userId])
  @@index([stopId])
}
