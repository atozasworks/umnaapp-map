// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String?   // Optional for OTP-only users
  googleId      String?   @unique
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  otpVerifications OTPVerification[]
  sessions         Session[]
  vehicles         Vehicle[]
  locations        Location[]
  routes           Route[]
  places           Place[]

  @@index([email])
  @@index([googleId])
}

model OTPVerification {
  id        String   @id @default(uuid())
  email     String
  otp       String
  type      String   // 'register' or 'login'
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  @@index([email, otp])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Vehicle {
  id          String   @id @default(uuid())
  name        String
  licensePlate String?  @unique
  type        String   // 'car', 'truck', 'bike', etc.
  status      String   @default("idle") // 'idle', 'active', 'maintenance'
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations   Location[]
  routes      Route[]

  @@index([userId])
  @@index([status])
}

model Location {
  id          String   @id @default(uuid())
  vehicleId   String?
  userId      String?
  latitude    Float
  longitude   Float
  accuracy    Float?   // GPS accuracy in meters
  speed       Float?   // Speed in km/h
  heading     Float?   // Direction in degrees (0-360)
  timestamp   DateTime @default(now())
  
  // PostGIS geometry column
  point       Unsupported("geometry(Point,4326)")?

  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([userId])
  @@index([timestamp])
  @@index([latitude, longitude])
}

model Route {
  id          String   @id @default(uuid())
  vehicleId   String?
  userId      String
  name        String?
  startLat    Float
  startLng    Float
  endLat      Float
  endLng      Float
  waypoints   Json?    // Array of {lat, lng} waypoints
  distance    Float?   // Distance in meters
  duration    Int?     // Duration in seconds
  polyline    String?  // Encoded polyline
  status      String   @default("planned") // 'planned', 'active', 'completed', 'cancelled'
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Place {
  id               String   @id @default(uuid())
  name             String   // Legacy: kept for backward compat; equals place_name_en for new places
  placeNameEn      String?  @map("place_name_en")   // English name (preferred)
  placeNameLocal   String?  @map("place_name_local") // Local language name (Kannada, Tamil, etc.)
  category         String   // Restaurant, Hospital, Hotel, Parking, Shop, Tourist Place, etc.
  latitude         Float
  longitude        Float
  zoomLevel        Float    @default(15)
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

