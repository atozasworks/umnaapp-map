# ============================================================================
# UMNAAPP frontend environment (Vite). Copy to `frontend/.env` and fill in.
#
# WEB / PWA:   leave VITE_API_URL EMPTY — the app uses the relative '/api'
#              base + dev proxy / same-origin in production (unchanged behavior).
# NATIVE:      Android (Capacitor) and Windows (Electron) have NO same-origin
#              server, so VITE_API_URL MUST be an absolute hosted backend URL
#              at build time.
# ============================================================================

# Absolute backend base URL — REQUIRED for native builds, leave blank for web.
# Example: https://umnaapptst.testatozas.in
VITE_API_URL=

# Tile server. For native this must be ABSOLUTE. Accepts either a base URL
# (we append /tiles/{z}/{x}/{y}.png) or a full XYZ template containing {z}/{x}/{y}.
# Example: https://umnaapp.in/tiles/{z}/{x}/{y}.png
VITE_TILESERVER_URL=

# Google OAuth Web client ID (used by the auth kit / GIS on web).
VITE_GOOGLE_CLIENT_ID=

# Optional: dedicated public maps subdomain (web only).
VITE_MAPS_HOST=

# Download URLs shown in the "Install App" section on the website.
# Defaults to /downloads/app.apk and /downloads/UmnaAppSetup.exe if unset.
VITE_APK_URL=
VITE_EXE_URL=
