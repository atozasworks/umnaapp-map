# Production API & app URL (backend + frontend served from same origin)
VITE_API_URL=https://umnaapptst.testatozas.in
# Tiles proxied by backend API (/api/map/tiles) → umnaapp.in (server-side, no CORS issue)
VITE_TILESERVER_URL=/api/map/tiles/{z}/{x}/{y}.png
# Google OAuth - add your production client ID (from Google Cloud Console) for testatozas.in
VITE_GOOGLE_CLIENT_ID=
