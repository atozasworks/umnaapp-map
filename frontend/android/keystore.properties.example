# Android release signing — copy to `keystore.properties` and fill in.
# Generate automatically with:  npm run keystore:generate
# storeFile is RELATIVE to the android/ directory (the rootProject for the app).
#
# NEVER commit the real keystore.properties or the .keystore file.
storeFile=keystore/umnaapp.keystore
storePassword=CHANGE_ME
keyAlias=umnaapp
keyPassword=CHANGE_ME
