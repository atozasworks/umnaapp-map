{
  "name": "umnaapp-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "UMNAAPP cross-platform client (Web/PWA, Android, Windows)",
  "author": "testatozas",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "ci:lint": "eslint src --max-warnings 200",
    "ci:audit": "npm audit --audit-level=high",
    "ci:build": "vite build",
    "ci:check": "npm run ci:lint && npm run ci:audit && npm run ci:build",
    "build:web:cap": "cross-env UMNA_TARGET=capacitor vite build",
    "build:web:electron": "cross-env UMNA_TARGET=electron vite build",
    "cap:sync": "npm run build:web:cap && cap sync",
    "cap:add:android": "cap add android",
    "android": "npm run build:web:cap && cap sync android && cap open android",
    "android:run": "npm run build:web:cap && cap run android",
    "build:apk": "node scripts/build-apk.mjs",
    "keystore:generate": "node scripts/gen-keystore.mjs",
    "desktop": "npm run build:web:electron && electron electron/main.cjs",
    "desktop:dev": "cross-env UMNA_DESKTOP_DEV_URL=http://localhost:3000 electron electron/main.cjs",
    "build:exe": "npm run build:web:electron && electron-builder --win && node scripts/collect-exe.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.5",
    "@capacitor/camera": "^6.1.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.3",
    "@capacitor/geolocation": "^6.1.0",
    "@capacitor/network": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@maplibre/maplibre-gl-geocoder": "^1.9.4",
    "@react-oauth/google": "^0.13.4",
    "electron-updater": "^6.3.9",
    "@turf/area": "^7.3.4",
    "atozas-react-auth-kit": "^1.0.1",
    "atozas-traslate": "^1.0.2",
    "axios": "^1.6.2",
    "jwt-decode": "^4.0.0",
    "maplibre-gl": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "socket.io-client": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.3.0"
  }
}
